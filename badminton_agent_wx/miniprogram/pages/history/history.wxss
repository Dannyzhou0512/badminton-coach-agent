.header {
  padding: 40rpx 0 32rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  color: #e8fff3;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #7a9e8e;
}

.history-card-list {
  display: flex;
  flex-direction: column;
}

.history-card {
  padding: 28rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.history-date {
  font-size: 28rpx;
  color: #e8fff3;
  font-weight: 600;
}

.history-score {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #5eff9f;
}

.score-label {
  font-size: 22rpx;
  color: #7a9e8e;
}

.history-stats {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx;
  background: rgba(10, 26, 20, 0.5);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.stat-mini {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-mini-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #5eff9f;
}

.stat-mini-label {
  font-size: 22rpx;
  color: #6b8a7d;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(94, 255, 159, 0.15);
}

.history-summary {
  font-size: 26rpx;
  color: #a0c4b4;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.history-arrow {
  font-size: 24rpx;
  color: #5eff9f;
  text-align: right;
}
