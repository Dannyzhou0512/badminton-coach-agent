.bind-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 40rpx;
  margin-top: 48rpx;
}

.bind-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.bind-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e8fff3;
  margin-bottom: 16rpx;
}

.bind-desc {
  font-size: 28rpx;
  color: #7a9e8e;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 48rpx;
}

.bind-input {
  width: 100%;
  height: 104rpx;
  background: rgba(94, 255, 159, 0.06);
  border: 2rpx solid rgba(94, 255, 159, 0.2);
  border-radius: 16rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 12rpx;
  color: #e8fff3;
  text-align: center;
  text-transform: uppercase;
  margin-bottom: 40rpx;
}

.bind-input::placeholder {
  font-size: 30rpx;
  font-weight: 400;
  letter-spacing: 2rpx;
  color: #4a6357;
}

.bind-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: rgba(94, 255, 159, 0.12);
  color: rgba(94, 255, 159, 0.5);
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 0;
  margin: 0;
  transition: all 0.2s ease;
}

.bind-btn::after {
  border: none;
}

.bind-btn.active {
  background: linear-gradient(135deg, #5eff9f, #3dd17e);
  color: #0a1a14;
  box-shadow: 0 8rpx 24rpx rgba(94, 255, 159, 0.25);
}

.bind-btn.active:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.bind-tip {
  text-align: center;
  font-size: 24rpx;
  color: #4a6357;
  margin-top: 32rpx;
}
