.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 32rpx;
}

.profile-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-avatar {
  width: 140rpx;
  height: 140rpx;
  font-size: 56rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-nickname {
  font-size: 36rpx;
  font-weight: 700;
  color: #e8fff3;
}

.user-username {
  font-size: 26rpx;
  color: #7a9e8e;
}

.wechat-badge {
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  align-self: flex-start;
  margin-top: 4rpx;
}

.edit-btn {
  padding: 12rpx 28rpx;
  background: rgba(94, 255, 159, 0.1);
  border: 1px solid rgba(94, 255, 159, 0.3);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #5eff9f;
}

.stats-card {
  padding: 32rpx;
}

.stats-grid {
  display: flex;
  gap: 20rpx;
}

.stat-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 0;
  background: rgba(94, 255, 159, 0.06);
  border-radius: 16rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #5eff9f;
}

.stat-text {
  font-size: 24rpx;
  color: #7a9e8e;
}

.menu-card {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  gap: 20rpx;
}

.menu-item:active {
  background: rgba(94, 255, 159, 0.05);
}

.menu-icon {
  font-size: 40rpx;
  width: 48rpx;
  text-align: center;
}

.wechat-icon {
  color: #07c160;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #e8fff3;
}

.menu-value {
  font-size: 26rpx;
  color: #7a9e8e;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #4a6357;
}

.menu-divider {
  height: 1rpx;
  background: rgba(94, 255, 159, 0.08);
  margin: 0 32rpx;
}

.logout-item .menu-text {
  color: #ff6b6b;
}

.version-info {
  text-align: center;
  font-size: 24rpx;
  color: #4a6357;
  margin-top: 48rpx;
  padding-bottom: 48rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background: #0f231a;
  border: 1rpx solid rgba(94, 255, 159, 0.15);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #e8fff3;
  text-align: center;
  margin-bottom: 40rpx;
}

.avatar-edit-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-edit-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(94, 255, 159, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #5eff9f;
  border: 2rpx solid rgba(94, 255, 159, 0.2);
}

.avatar-edit-preview image {
  width: 100%;
  height: 100%;
}

.avatar-edit-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #5eff9f;
}

.form-row {
  margin-bottom: 40rpx;
}

.form-label {
  font-size: 28rpx;
  color: #7a9e8e;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: rgba(94, 255, 159, 0.06);
  border: 1rpx solid rgba(94, 255, 159, 0.15);
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  color: #e8fff3;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 0;
  margin: 0;
  border: none;
}

.modal-btn::after {
  border: none;
}

.modal-btn.cancel {
  background: rgba(94, 255, 159, 0.08);
  color: #7a9e8e;
}

.modal-btn.confirm {
  background: #5eff9f;
  color: #05140e;
}
