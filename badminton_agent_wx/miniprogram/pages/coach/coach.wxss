.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 0;
}

.header {
  padding: 32rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.chat-messages {
  flex: 1;
  padding: 0 24rpx;
  overflow-y: auto;
}

.welcome-section {
  padding: 60rpx 40rpx;
  text-align: center;
}

.welcome-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.welcome-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #e8fff3;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #7a9e8e;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.quick-questions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
}

.quick-q {
  padding: 16rpx 28rpx;
  background: rgba(94, 255, 159, 0.1);
  border: 1px solid rgba(94, 255, 159, 0.25);
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #5eff9f;
}

.message-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 28rpx;
  align-items: flex-start;
}

.message-row.user {
  flex-direction: row-reverse;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-word;
}

.coach-bubble {
  background: linear-gradient(145deg, #0f281f, #133025);
  border: 1px solid rgba(94, 255, 159, 0.15);
  color: #e8fff3;
  border-top-left-radius: 4rpx;
}

.user-bubble {
  background: linear-gradient(135deg, #5eff9f, #3dd17e);
  color: #0a1a14;
  border-top-right-radius: 4rpx;
  font-weight: 500;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.coach-avatar {
  background: linear-gradient(135deg, #5eff9f, #3dd17e);
  color: #0a1a14;
}

.user-avatar {
  background: linear-gradient(135deg, #2a9d60, #1e7545);
  color: #e8fff3;
}

.typing {
  padding: 24rpx;
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.typing-dots .dot {
  width: 12rpx;
  height: 12rpx;
  background: #5eff9f;
  border-radius: 50%;
  animation: typingBounce 1.4s ease-in-out infinite;
}

.typing-dots .dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dots .dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typingBounce {
  0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-12rpx); opacity: 1; }
}

.chat-input-area {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #0d2219;
  border-top: 1rpx solid rgba(94, 255, 159, 0.1);
  flex-shrink: 0;
}

.chat-input {
  flex: 1;
  height: 80rpx;
  background: rgba(10, 26, 20, 0.8);
  border: 1rpx solid rgba(94, 255, 159, 0.2);
  border-radius: 40rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #e8fff3;
}

.input-placeholder {
  color: #4a6357;
}

.send-btn {
  width: 120rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #5eff9f, #3dd17e);
  color: #0a1a14;
  border: none;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
  line-height: 80rpx;
}

.send-btn[disabled] {
  opacity: 0.4;
}
