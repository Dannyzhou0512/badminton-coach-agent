<view class="container">
  <view class="header">
    <view class="kicker">HISTORY</view>
    <view class="title">训练历史</view>
    <view class="subtitle">查看你的所有训练分析记录</view>
  </view>

  <view wx:if="{{historyList.length === 0}}" class="empty-state card">
    <view class="empty-icon">📋</view>
    <view class="empty-title">暂无训练记录</view>
    <view class="empty-desc">完成一次视频分析后，记录会显示在这里</view>
  </view>

  <view wx:else class="history-card-list">
    <view wx:for="{{historyList}}" wx:key="id" class="card history-card" bindtap="viewDetail" data-id="{{item.id}}">
      <view class="history-header">
        <view class="history-date">{{item.date}}</view>
        <view class="history-score" wx:if="{{item.score}}">
          <text class="score-value">{{item.score}}</text>
          <text class="score-label">分</text>
        </view>
      </view>
      <view class="history-stats" wx:if="{{item.stats}}">
        <view class="stat-mini">
          <text class="stat-mini-value">{{item.stats.shots || 0}}</text>
          <text class="stat-mini-label">击球</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-mini">
          <text class="stat-mini-value">{{item.stats.duration || '--'}}</text>
          <text class="stat-mini-label">时长</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-mini">
          <text class="stat-mini-value">{{item.stats.movement || '--'}}</text>
          <text class="stat-mini-label">移动</text>
        </view>
      </view>
      <view class="history-summary" wx:if="{{item.summary}}">
        {{item.summary}}
      </view>
      <view class="history-arrow">查看详情 ›</view>
    </view>
  </view>
</view>
