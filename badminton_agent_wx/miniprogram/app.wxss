page {
  background-color: #0a1a14;
  color: #e8fff3;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  min-height: 100vh;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: linear-gradient(145deg, #0f281f, #133025);
  border: 1px solid rgba(94, 255, 159, 0.12);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.btn-primary {
  background: linear-gradient(135deg, #5eff9f, #3dd17e);
  color: #0a1a14;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(94, 255, 159, 0.25);
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  background: rgba(94, 255, 159, 0.08);
  color: #5eff9f;
  border: 1px solid rgba(94, 255, 159, 0.3);
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.btn-secondary:active {
  background: rgba(94, 255, 159, 0.15);
}

.btn-wechat {
  background: #07c160;
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-wechat:active {
  opacity: 0.85;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e8fff3;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #7a9e8e;
  margin-bottom: 32rpx;
}

.kicker {
  font-size: 22rpx;
  font-weight: 600;
  color: #5eff9f;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #e8fff3;
  margin-bottom: 16rpx;
}

.text-muted {
  color: #6b8a7d;
  font-size: 26rpx;
}

.text-accent {
  color: #5eff9f;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.gap-12 {
  gap: 12rpx;
}

.gap-16 {
  gap: 16rpx;
}

.gap-24 {
  gap: 24rpx;
}

.mb-16 {
  margin-bottom: 16rpx;
}

.mb-24 {
  margin-bottom: 24rpx;
}

.mb-32 {
  margin-bottom: 32rpx;
}

.mt-24 {
  margin-top: 24rpx;
}

.w-full {
  width: 100%;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #5eff9f, #3dd17e);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #0a1a14;
}

.avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(10, 26, 20, 0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(94, 255, 159, 0.2);
  border-top-color: #5eff9f;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #5eff9f;
  font-size: 28rpx;
}
