.header {
  padding: 40rpx 0 32rpx;
}

.upload-card {
  padding: 32rpx;
}

.upload-area {
  width: 100%;
  min-height: 360rpx;
  background: rgba(10, 26, 20, 0.6);
  border: 2rpx dashed rgba(94, 255, 159, 0.3);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  width: 100%;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  font-size: 30rpx;
  color: #e8fff3;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #6b8a7d;
}

.video-preview {
  width: 100%;
  padding: 16rpx;
  box-sizing: border-box;
}

.preview-video {
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx;
  background: #000;
}

.video-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 8rpx 8rpx;
}

.video-name {
  font-size: 28rpx;
  color: #e8fff3;
}

.video-size {
  font-size: 24rpx;
  color: #7a9e8e;
}

.reselect-btn {
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: #5eff9f;
  background: rgba(94, 255, 159, 0.08);
  border: 1rpx solid rgba(94, 255, 159, 0.2);
  border-radius: 12rpx;
  margin: 8rpx 8rpx 0;
}

.config-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(10, 26, 20, 0.4);
  border-radius: 12rpx;
}

.config-label {
  font-size: 28rpx;
  color: #b8d4c7;
}

.picker-value {
  font-size: 28rpx;
  color: #5eff9f;
}

.tips-card {
  padding: 32rpx;
}

.tip-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.tip-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(94, 255, 159, 0.15);
  color: #5eff9f;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #a0c4b4;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(94, 255, 159, 0.08);
}

.history-item:last-child {
  border-bottom: none;
}

.history-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-date {
  font-size: 26rpx;
  color: #6b8a7d;
}

.history-summary {
  font-size: 28rpx;
  color: #e8fff3;
}

.history-arrow {
  font-size: 40rpx;
  color: #5eff9f;
}

.progress-bar-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80%;
  margin-top: 24rpx;
}

.progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(94, 255, 159, 0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #5eff9f, #3dd17e);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #5eff9f;
  margin-top: 12rpx;
}
